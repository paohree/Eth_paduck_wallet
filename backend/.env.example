# ──────────────────────────────────────────────────────
# .env.example — 실제 .env 파일을 만들 때 이 파일을 복사해서 사용하세요.
# cp .env.example .env  →  .env 편집 후 실제 값 입력
#
# [왜 .env 파일이 필요한가]
# Alchemy API 키는 이 서비스가 Ethereum 노드에 접근할 수 있는 비밀 자격증명이다.
# 이 키가 소스 코드에 하드코딩되거나 Git에 올라가면,
# 누구나 GitHub에서 찾아 무제한으로 사용할 수 있다.
# 환경변수로 관리하면 코드와 비밀값이 완전히 분리된다.
#
# [.gitignore에 .env가 포함된 이유]
# 실수로 git add . 했을 때 .env가 커밋되지 않도록 보호한다.
# ──────────────────────────────────────────────────────

# Alchemy Sepolia RPC URL (API 키 포함)
# Alchemy 대시보드 → Apps → API Key → HTTPS URL 복사
# 예시: https://eth-sepolia.g.alchemy.com/v2/abcdefg1234567
ALCHEMY_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY_HERE

# 서버 포트 (기본값: 5000)
PORT=5000

# 허용할 프론트엔드 Origin (CORS)
# 개발 환경에서는 http://localhost:5173 (Vite 기본 포트)
# 배포 환경에서는 실제 도메인으로 변경
ALLOWED_ORIGIN=http://localhost:5173
